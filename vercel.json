{
  "version": 2,
  "buildCommand": "pnpm install --ignore-scripts && pnpm --filter \"./artifacts/gifts-n-more\" run build && rm -rf dist && mv artifacts/gifts-n-more/dist dist",
  "outputDirectory": "dist",
  "installCommand": "pnpm install --ignore-scripts",
  "framework": "vite",
  "routes": [
    {
      "src": "/api/(.*)",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET,POST,PUT,DELETE,OPTIONS,PATCH",
        "Access-Control-Allow-Headers": "Content-Type,Authorization"
      },
      "dest": "/api/index"
    },
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
